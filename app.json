{
  "_comment": "This file is generated. Please edit .homeycompose/app.json instead.",
  "id": "com.mypetsafe",
  "version": "1.0.0",
  "compatibility": ">=12.2.0",
  "sdk": 3,
  "platforms": [
    "local"
  ],
  "name": {
    "en": "MyPetSafe"
  },
  "description": {
    "en": ""
  },
  "category": [
    "appliances"
  ],
  "tags": {},
  "brandColor": "#083874",
  "homepage": "https://www.petsafe.com/",
  "source": "https://github.com/StefanIndustries/HomeyMyPetSafe",
  "bugs": {
    "url": "https://github.com/StefanIndustries/HomeyMyPetSafe/issues"
  },
  "permissions": [],
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "author": {
    "name": "Stefan Simon"
  },
  "contributing": {
    "donate": {
      "bunq": {
        "username": "StefanJSimon"
      }
    }
  },
  "flow": {
    "actions": [
      {
        "id": "feed_now",
        "title": "{{capability.feed_now.title}}",
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=feeder"
          }
        ]
      }
    ]
  },
  "drivers": [
    {
      "name": "{{driver.feeder.name}}",
      "class": "petfeeder",
      "capabilities": [
        "measure_battery",
        "alarm_battery",
        "alarm_power",
        "alarm_low_food",
        "alarm_no_food",
        "last_feeding_time",
        "locked",
        "button_feed"
      ],
      "platforms": [
        "local"
      ],
      "connectivity": [
        "cloud"
      ],
      "energy": {
        "batteries": [
          "OTHER"
        ]
      },
      "images": {
        "small": "/drivers/feeder/assets/images/small.png",
        "large": "/drivers/feeder/assets/images/large.png",
        "xlarge": "/drivers/feeder/assets/images/xlarge.png"
      },
      "pair": [
        {
          "id": "prepare_pair",
          "template": "loading"
        },
        {
          "id": "email",
          "navigation": {
            "next": "pincode"
          }
        },
        {
          "id": "pincode",
          "template": "pincode",
          "options": {
            "title": "{{pair.pincode.title}}",
            "hint": "{{pair.pincode.hint}}",
            "type": "number",
            "length": 6
          },
          "navigation": {
            "next": "list_devices"
          }
        },
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": {
            "next": "add_devices"
          }
        },
        {
          "id": "add_devices",
          "template": "add_devices",
          "navigation": {
            "next": "done"
          }
        },
        {
          "id": "done",
          "template": "done"
        }
      ],
      "flow": {
        "actions": [
          {
            "id": "feed_now",
            "title": "{{capability.feed_now.title}}"
          }
        ]
      },
      "id": "feeder"
    }
  ],
  "capabilities": {
    "alarm_low_food": {
      "type": "boolean",
      "getable": true,
      "setable": false,
      "insights": false,
      "title": "{{capability.alarm_low_food.title}}"
    },
    "alarm_no_food": {
      "type": "boolean",
      "getable": true,
      "setable": false,
      "insights": false,
      "title": "{{capability.alarm_no_food.title}}"
    },
    "button_feed": {
      "title": "{{capability.feed_now.title}}",
      "type": "boolean",
      "getable": false,
      "setable": true,
      "uiComponent": "button",
      "uiQuickAction": true
    },
    "last_feeding_time": {
      "type": "string",
      "title": "{{capability.last_feeding_time.title}}",
      "getable": true,
      "setable": false
    }
  }
}