{
  "name": "{{driver.feeder.name}}",
  "class": "petfeeder",
  "capabilities": [
    "measure_battery",
    "alarm_battery",
    "alarm_power",
    "alarm_low_food",
    "alarm_no_food",
    "last_feeding_time",
    "locked",
    "button_feed"
  ],
  "platforms": [
    "local"
  ],
  "connectivity": [
    "cloud"
  ],
  "energy": {
    "batteries": ["OTHER"]
  },
  "images": {
    "small": "{{driverAssetsPath}}/images/small.png",
    "large": "{{driverAssetsPath}}/images/large.png",
    "xlarge": "{{driverAssetsPath}}/images/xlarge.png"
  },
  "pair": [
    {
      "id": "prepare_pair",
      "template": "loading"
    },
    {
      "id": "email",
      "navigation": { "next": "pincode" }
    },
    {
      "id": "pincode",
      "template": "pincode",
      "options": {
        "title": "{{pair.pincode.title}}",
        "hint": "{{pair.pincode.hint}}",
        "type": "number",
        "length": 6
      },
      "navigation": { "next": "list_devices" }
    },
    {
      "id": "list_devices",
      "template": "list_devices",
      "navigation": { "next": "add_devices" }
    },
    {
      "id": "add_devices",
      "template": "add_devices",
      "navigation": { "next": "done" }
    },
    {
      "id": "done",
      "template": "done"
    }
  ],
  "flow": {
    "actions": [
      {
        "id": "feed_now",
        "title": "{{capability.feed_now.title}}"
      }
    ]
  }
}