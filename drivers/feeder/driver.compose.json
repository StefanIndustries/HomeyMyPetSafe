{
  "name": {
    "ar": "وحدة تغذية",
    "da": "Foderautomat",
    "de": "Futterautomat",
    "en": "feeder",
    "es": "Alimentador",
    "fr": "Distributeur",
    "it": "Distributore",
    "ko": "급식기",
    "nl": "voederbak",
    "no": "Mater",
    "pl": "Podajnik",
    "ru": "Кормушка",
    "sv": "Matare"
  },
  "class": "petfeeder",
  "capabilities": [
    "measure_battery",
    "alarm_battery",
    "alarm_power",
    "alarm_low_food",
    "alarm_no_food",
    "last_feeding_time",
    "locked",
    "button_feed"
  ],
  "platforms": [
    "local"
  ],
  "connectivity": [
    "cloud"
  ],
  "energy": {
    "batteries": ["OTHER"]
